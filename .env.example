# =============================================================================
# Environment Variables — AI Capability Radar
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file containing real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (https://supabase.com/dashboard)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Cron Security (shared between GitHub Actions and this app)
# Generate: openssl rand -hex 32
# -----------------------------------------------------------------------------
CRON_SECRET=your-cron-secret-here

# -----------------------------------------------------------------------------
# Anthropic Claude API (https://console.anthropic.com)
# Used for: capability delta extraction, business impact mapping, briefings
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here

# -----------------------------------------------------------------------------
# Resend (https://resend.com/api-keys)
# Used for: alert emails, weekly briefing delivery, password reset
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_your-key-here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# Upstash Redis (https://console.upstash.com)
# Used for: API rate limiting
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# -----------------------------------------------------------------------------
# GitHub API (https://github.com/settings/tokens)
# Scope: public_repo (read-only) — for ingesting trending repos
# -----------------------------------------------------------------------------
GITHUB_TOKEN=ghp_your-token-here

# -----------------------------------------------------------------------------
# Product Hunt API (https://www.producthunt.com/v2/oauth/applications)
# Used for: ingesting newly launched AI products
# -----------------------------------------------------------------------------
PRODUCTHUNT_API_TOKEN=your-token-here

# -----------------------------------------------------------------------------
# (Optional) Slack — set per-user in profile preferences, not here
# SLACK_WEBHOOK_URL is stored in profiles.preferences, not as a server env var
# -----------------------------------------------------------------------------
